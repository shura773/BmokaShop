# ---- Server ----
PORT=3000

# ---- PayWay (ABA) ----
# Leave PAYWAY_MERCHANT_ID / PAYWAY_API_KEY empty to run in DEMO_MODE
# (fake QR codes, no real bank calls — good for building/testing the site itself).
#
# To go live:
# 1. Get a sandbox account at https://developer.payway.com.kh/ (free, self-serve)
# 2. For production credentials, email paywaysales@ababank.com
# 3. Paste the Merchant ID + API Key they give you below
PAYWAY_MERCHANT_ID=
PAYWAY_API_KEY=

# sandbox or production — controls which PayWay base URL is used
PAYWAY_ENV=sandbox

# ---- Shipping ----
FLAT_SHIPPING_USD=6

# ---- Admin dashboard ----
# Only ONE admin account, configured here (not in the database).
# Change these before deploying anywhere public.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# ---- Email (Resend) ----
# Leave RESEND_API_KEY empty to run in DEMO_MODE (emails are logged to the
# console instead of actually sent — good for local dev).
#
# To send real emails:
# 1. Sign up free at https://resend.com (no credit card needed, 3,000
#    emails/month free)
# 2. Create an API key in their dashboard
# 3. Paste it below
# 4. EMAIL_FROM can stay as the shared onboarding@resend.dev address for
#    testing — to send from your own domain (e.g. hello@myshop.com),
#    verify that domain in the Resend dashboard first, then update this.
RESEND_API_KEY=
EMAIL_FROM=MyShop <onboarding@resend.dev>

# Public base URL of your site — used to build links inside emails (like
# the password reset link). Update this once you deploy somewhere real.
PUBLIC_BASE_URL=http://localhost:3000
